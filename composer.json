{
    "name": "kode/aop",
    "description": "基于 PHP 8.1+ 原生属性（Attribute）实现的轻量级、高性能、高扩展性 AOP（面向切面编程）组件",
    "keywords": ["aop", "aspect", "proxy", "attribute", "php81", "php82", "php83"],
    "homepage": "https://github.com/kodephp/aop",
    "license": "Apache-2.0",
    "version": "2.0.0",
    "authors": [
        {
            "name": "Kode Team",
            "email": "382601296@qq.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Aop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Aop\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "coverage": "phpunit --coverage-html coverage",
        "analyse": "phpstan analyse src tests --level=8",
        "cs-check": "phpcs src tests",
        "cs-fix": "phpcbf src tests",
        "example": "php examples/demo.php"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
